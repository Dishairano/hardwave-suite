{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hardwave Suite Setup",
  "version": "0.1.0",
  "identifier": "com.hardwavestudios.suite.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hardwave Suite Setup",
        "width": 720,
        "height": 520,
        "minWidth": 720,
        "minHeight": 520,
        "maxWidth": 720,
        "maxHeight": 520,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "compression": "lzma",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {}
}
