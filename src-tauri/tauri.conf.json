{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hardwave Suite",
  "version": "0.6.0",
  "identifier": "com.hardwavestudios.suite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hardwave Suite",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2NTAwNEY3RTVCRTU4QUEKUldTcVdMN2w5d1JRUnAxQm1Cd3lNRjh5ellqU3AySHFQS3ZzVWpDckE0amYwTGdJMUNwT3BWWEwK",
      "endpoints": [
        "https://hardwarestudios.com/api/updates/hardwave-suite/latest"
      ]
    }
  }
}