{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Hardwave Suite",
  "version": "0.5.6",
  "identifier": "com.hardwavestudios.organizer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hardwave Suite",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https:; media-src 'self' asset: file:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg", "deb", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Hardwave Studios",
    "copyright": "Copyright 2026 Hardwave Studios",
    "category": "Music",
    "shortDescription": "Production toolkit for harder-styles producers",
    "longDescription": "Hardwave Suite is the ultimate production toolkit for hardstyle, rawstyle, and hardcore producers. Sample organization, kick synthesis, lightning-fast search, and seamless workflow integration.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Dishairano/hardwave-suite-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4NjlBNURFOEEwRjI4MzgKUldRNEtBK0szcVZwNkhyRk9LcHF2c2tXUzNFbkZtT2F6U0lFRDVFaERqMWM1SXRsTGxVUkU0RWgK"
    }
  }
}
