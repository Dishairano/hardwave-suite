# ── Database ──────────────────────────────────────────────────────────────────
# MySQL runs on the static-pages server (46.225.219.184).
# DATABASE_HOST is overridden per-server in docker-compose environment:
#   - static-pages server:    DATABASE_HOST=database  (Docker service name)
#   - erp/analyser/wettboi:   DATABASE_HOST=46.225.219.184  (set in compose)
# Leave DATABASE_HOST blank here — it is always overridden by docker-compose.
DATABASE_HOST=
DATABASE_PORT=3306
DATABASE_USER=hardwave
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=hardwave
# Root password — only needed for running migrations from setup-static-pages.sh
DATABASE_ROOT_PASSWORD=your_db_root_password

# ── Authentication ─────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here

# ── App URL ───────────────────────────────────────────────────────────────────
# NEXTAUTH_URL is set per-server in docker-compose environment, not here.
NEXT_PUBLIC_APP_URL=https://hardwavestudios.com

# ── File paths ────────────────────────────────────────────────────────────────
# Directory for large installer downloads served by /api/download-file/*
# Mounted as a read-only volume in the static-pages docker-compose.
PUBLIC_DOWNLOADS_DIR=/public-downloads

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID=price_xxxxx

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
