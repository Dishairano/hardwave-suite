{
  "name": "hardwave-studios",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "build:main": "turbo build --filter=@hardwave/main",
    "build:erp": "turbo build --filter=@hardwave/erp",
    "build:analyser": "turbo build --filter=@hardwave/analyser-app",
    "build:wettboi": "turbo build --filter=@hardwave/wettboi-app",
    "migrate": "npx tsx scripts/migrate.ts",
    "migrate:status": "npx tsx scripts/migrate.ts --status",
    "migrate:dry": "npx tsx scripts/migrate.ts --dry-run"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "tsx": "^4.19.2",
    "mysql2": "^3.16.1"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  }
}
