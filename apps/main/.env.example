# Deployment scope — controls which routes this instance serves
# Values: public | erp | analyser | wettboi
SITE_SCOPE=public

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=your_user
DATABASE_PASSWORD=your_password
DATABASE_NAME=hardwave

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# App URL
NEXT_PUBLIC_APP_URL=https://hardwavestudios.com

# Public downloads directory (for large installers / updater manifests)
# Used by /api/download-file/* and /api/updates/hardwave-suite/latest
PUBLIC_DOWNLOADS_DIR=/home/cnstexultant/hardwave-uploads/public-downloads

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID=price_xxxxx

# Note: Create a price in Stripe Dashboard for EUR 10.00/month
# Set STRIPE_PRICE_ID to that price ID
